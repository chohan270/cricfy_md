# ── Malik Chohan MD — Environment Config ──────────────────────────────
# Copy this file to .env and fill in your own values.

# Unique session identifier (used as your MongoDB collection prefix)
SESSION_ID=malik_session

# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=

# Your own WhatsApp number (with country code, no + or spaces)
# Used so owner-only commands (.af set / .af global) work even when
# a linked device other than the primary phone sends the command.
OWNER_NUMBER=

# Optional: comma-separated exact phrases to strip out of forwarded
# text/captions before relaying (e.g. old channel names/links)
OLD_TEXT_REGEX=

# Optional: replacement text for anything matched by OLD_TEXT_REGEX
NEW_TEXT=

# Port for the web dashboard (Heroku/most hosts set this automatically)
PORT=3000
